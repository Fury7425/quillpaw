{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "dialog:default",
    "notification:default",
    "store:default",
    "main:allow-open-vault",
    "main:allow-get-file-tree",
    "main:allow-read-note",
    "main:allow-save-note",
    "main:allow-create-note",
    "main:allow-delete-item",
    "main:allow-rename-item",
    "main:allow-create-folder",
    "main:allow-import-asset",
    "main:allow-resolve-asset",
    "main:allow-build-search-index",
    "main:allow-build-embeddings",
    "main:allow-search-notes",
    "main:allow-search-semantic",
    "main:allow-load-ai-model",
    "main:allow-unload-ai-model",
    "main:allow-get-ai-status",
    "main:allow-detect-npu",
    "main:allow-download-ai-model",
    "main:allow-summarize-note",
    "main:allow-ask-question",
    "main:allow-detect-reminders",
    "main:allow-suggest-tags",
    "main:allow-apply-ai-proposal",
    "main:allow-start-lecture-mode",
    "main:allow-stop-lecture-mode",
    "main:allow-list-audio-devices",
    "main:allow-set-audio-device",
    "main:allow-set-stt-model-path",
    "main:allow-render-drawing-png",
    "main:allow-save-drawing",
    "main:allow-load-drawing"
  ]
}
